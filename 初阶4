//来证明：函数里的形参改变不会影响到 主函数里的实参变化，但可以通过指针达成改变
void swap(int*x,int*y)
{
	int z = *x;
	*x = *y;
	*y = z;

}
int main()
{
	int a = 0;
	int b = 0;
	scanf("%d%d", &a, &b);
	printf("交换前，a=%d，b=%d", a, b);
	swap(&a,&b);
	printf("交换后，a=%d，b=%d", a, b);
	return 0;

}
