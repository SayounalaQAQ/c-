struct stu
{
	char name[10];
	int age;
	char sex[10];
	char tele[10];
};
void print(struct stu* ps)
{
	printf("%s %d %s %s\n", (*ps).name, (*ps).age, (*ps).sex, (*ps).tele);
	printf("%s %d %s %s\n", ps->name, ps->age ,ps->sex ,ps->tele);
}
int main()
{
	struct stu s = { "zhangsan",19,"nan","120" };
	printf("%s %d %s %s\n", s.name, s.age, s.sex, s.tele);
	struct stu* b = &s;
	print(b);
	return 0;
}
