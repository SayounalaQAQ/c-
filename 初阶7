//删除数组中指定数值
int main()
{
	//输入n，代表数组存储n个数
	int n = 0;
	scanf("%d", &n);
	//创建数组，往数组里存数
	int i = 0;
	int arr[50] = { 0 };
	for (i = 0; i < n; i++)
	{
		scanf("%d", arr + i);
		//scanf("%d",&arr[i]);
	}
	//指定删除的数
	int del = 0;
	scanf("%d", &del);
	//开始遍历
	int j = 0;//设定新的下标
	for (i = 0; i < n; i++)
	{
		if (arr[i] != del)
		{
			arr[j++] = arr[i];
		}
	}
	for (i = 0; i < j; i++)
	{
		printf("%d ", arr[i]);
	}
	return 0;
}
